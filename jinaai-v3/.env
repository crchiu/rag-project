# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=project_rag

# Embeddings (Local HF, remote code)
EMBEDDING_MODEL=jinaai/jina-embeddings-v3

# Chunking
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# Retrieval
TOP_K=10
DOMINANT_SECTION_RATIO=0.6
MIN_TOP_SCORE=0.35

# OCR fallback
OCR_ENABLED=true
OCR_LANG=chi_tra+eng
OCR_DPI=220
OCR_MIN_CHARS_PER_PAGE=30
OCR_PAGE_RATIO=0.6
OCR_TOTAL_MIN_CHARS=300
OCR_MAX_PAGES=60