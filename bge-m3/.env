# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=project_rag

# Models
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=jinaai/jina-reranker-v2-base-multilingual

# Chunking
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# Retrieval
TOP_K=10
SEARCH_CANDIDATES=40   # 先向量取前N，再rerank縮到TOP_K

# OCR fallback
OCR_ENABLED=true
OCR_LANG=chi_tra+eng
OCR_DPI=220
OCR_MIN_CHARS_PER_PAGE=30
OCR_PAGE_RATIO=0.6
OCR_TOTAL_MIN_CHARS=300
OCR_MAX_PAGES=60

DEVICE=auto
RERANK_BATCH=32
EMBED_BATCH=32
SEARCH_CANDIDATES=20
TOP_K=8