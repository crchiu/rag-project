QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=project_rag_v4_native

EMBEDDING_MODEL=jinaai/jina-embeddings-v4
EMBED_TRUNCATE_DIM=1024

RERANKER_MODEL=jinaai/jina-reranker-v2-base-multilingual

DEVICE=auto
EMBED_DTYPE=bf16
RERANK_DTYPE=fp16

TOP_K=8
SEARCH_CANDIDATES=20
EMBED_BATCH=8
RERANK_BATCH=16

CHUNK_SIZE=900
CHUNK_OVERLAP=150

OCR_ENABLED=true
OCR_LANG=chi_tra+eng
OCR_DPI=220
OCR_MIN_CHARS_PER_PAGE=30
OCR_PAGE_RATIO=0.6
OCR_TOTAL_MIN_CHARS=300
OCR_MAX_PAGES=60